---
import footerData from "../data/footer.json";
---

<footer class="bg-blue-900 text-gray-200 mt-20">
  <div class="max-w-7xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-8">

    <div>
      <h3 class="font-bold text-lg mb-3">Tentang Sekolah</h3>
      <p class="text-sm leading-relaxed text-gray-300">
        {footerData.about}
      </p>
    </div>

    <div>
      <h3 class="font-bold text-lg mb-3">Menu</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/" class="hover:underline">Beranda</a></li>
        <li><a href="/profil" class="hover:underline">Profil</a></li>
        <li><a href="/berita" class="hover:underline">Berita</a></li>
        <li><a href="/kontak" class="hover:underline">Kontak</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-bold text-lg mb-3">Kontak</h3>
      <p class="text-sm text-gray-300">
        {footerData.address}<br />
        Email: {footerData.email}<br />
        Telp: {footerData.phone}
      </p>
    </div>

  </div>

  <div class="text-center text-sm bg-blue-950 py-4">
    © {new Date().getFullYear()} {footerData.copyright}. All rights reserved.
  </div>
</footer>
