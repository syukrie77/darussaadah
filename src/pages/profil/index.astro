---
import MainLayout from "../../layouts/MainLayout.astro";
import profilData from "../../data/profil.json";

const sambutanParagraphs = profilData.sambutan.split("\n\n").filter(Boolean);
---

<MainLayout title="Profil Sekolah | SMK Bina Mandiri Kutabumi">
  <section class="py-24 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">

      <!-- Judul -->
      <h1 class="text-4xl font-bold text-gray-800 mb-10">
        Profil Sekolah
      </h1>

      <!-- Perkenalan & Info Sekolah -->
      <div class="grid md:grid-cols-2 gap-10 items-center mb-16">
        <div>
          <p class="text-gray-700 leading-relaxed mb-4">
            {profilData.intro1}
          </p>
          <p class="text-gray-700 leading-relaxed">
            {profilData.intro2}
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow p-6">
          <ul class="space-y-3 text-gray-700">
            <li><strong>Nama Sekolah:</strong> {profilData.nama_sekolah}</li>
            <li><strong>NPSN:</strong> {profilData.npsn}</li>
            <li><strong>Status:</strong> {profilData.status}</li>
            <li><strong>Akreditasi:</strong> {profilData.akreditasi}</li>
            <li><strong>Tahun Berdiri:</strong> {profilData.tahun_berdiri}</li>
          </ul>
        </div>
      </div>

      <!-- Sambutan Kepala Sekolah -->
      <div class="bg-white rounded-2xl shadow p-8 mb-16">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">
          Sambutan Kepala Sekolah
        </h2>

        <div class="grid md:grid-cols-3 gap-8 items-start">
          <div class="flex justify-center">
            <img
              src={profilData.kepala_sekolah_foto}
              alt={`Foto ${profilData.kepala_sekolah_nama}`}
              class="w-48 h-auto rounded-xl shadow"
            />
          </div>

          <div class="md:col-span-2 text-gray-700 leading-relaxed space-y-4">
            {sambutanParagraphs.map((para) => (
              <p>{para}</p>
            ))}
            <p class="mt-6 font-semibold">
              {profilData.kepala_sekolah_nama}
            </p>
          </div>
        </div>
      </div>

      <!-- Visi -->
      <div class="bg-white rounded-2xl shadow p-8 mb-10">
        <h2 class="text-2xl font-bold text-gray-800 mb-4">Visi</h2>
        <p class="text-gray-700 leading-relaxed">{profilData.visi}</p>
      </div>

      <!-- Misi -->
      <div class="bg-white rounded-2xl shadow p-8">
        <h2 class="text-2xl font-bold text-gray-800 mb-4">Misi</h2>
        <ul class="list-disc list-inside space-y-3 text-gray-700">
          {profilData.misi.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

    </div>
  </section>
</MainLayout>
