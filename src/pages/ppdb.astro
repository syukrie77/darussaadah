---
import MainLayout from "../layouts/MainLayout.astro";
import ppdbData from "../data/ppdb.json";
---

<MainLayout title="PPDB | SMK Bina Mandiri Kutabumi">
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold text-gray-800 mb-4">
          {ppdbData.title}
        </h1>
        <p class="text-gray-600 max-w-3xl mx-auto">
          Tahun Ajaran {ppdbData.tahun_ajaran}
          <br />
          {ppdbData.subtitle}
        </p>
      </div>

      <!-- Highlight Keunggulan -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {ppdbData.highlights.map((h) => (
          <div class="bg-white rounded-xl shadow p-6 text-center">
            <div class="text-3xl mb-2">{h.icon}</div>
            <h3 class="font-semibold">{h.title}</h3>
            <p class="text-sm text-gray-600">{h.desc}</p>
          </div>
        ))}
      </div>

      <!-- Jurusan -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">
          Program Keahlian
        </h2>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl shadow p-6 text-center">
            <img src="/images/jurusan/tkj.png" alt="TKJ" class="w-20 h-20 mx-auto mb-4" />
            <h3 class="font-bold">TKJ</h3>
            <p class="text-sm text-gray-600">Teknik Komputer dan Jaringan</p>
          </div>

          <div class="bg-white rounded-2xl shadow p-6 text-center">
            <img src="/images/jurusan/tata-busana.png" alt="Tata Busana" class="w-20 h-20 mx-auto mb-4" />
            <h3 class="font-bold">Tata Busana</h3>
            <p class="text-sm text-gray-600">Garmen & Fashion</p>
          </div>

          <div class="bg-white rounded-2xl shadow p-6 text-center">
            <img src="/images/jurusan/bisnis-online.png" alt="Bisnis Daring" class="w-20 h-20 mx-auto mb-4" />
            <h3 class="font-bold">Bisnis Daring</h3>
            <p class="text-sm text-gray-600">Digital Marketing & E-Commerce</p>
          </div>
        </div>
      </div>

      <!-- Alur Pendaftaran -->
      <div class="bg-white rounded-2xl shadow p-10 mb-16">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">
          Alur Pendaftaran PPDB
        </h2>
        <ol class="list-decimal list-inside space-y-3 text-gray-700">
          {ppdbData.alur.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </div>

      <!-- Tombol Daftar -->
      <div class="text-center">
        <a
          href={`https://wa.me/${ppdbData.wa_number}`}
          target="_blank"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-10 py-4 rounded-xl transition"
        >
          {ppdbData.button_text}
        </a>
        <p class="text-sm text-gray-500 mt-4">
          Atau hubungi panitia PPDB melalui WhatsApp
        </p>
      </div>

    </div>
  </section>
</MainLayout>
