---
import MainLayout from "../layouts/MainLayout.astro";
import jurusanData from "../data/jurusan.json";
import siteData from "../data/site.json";

const { title, subtitle, jurusan } = jurusanData;
---

<MainLayout title={`${title} | ${siteData.name}`}>
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">

      <h1 class="text-4xl font-bold text-gray-800 mb-4">
        {title}
      </h1>
      <p class="text-gray-600 mb-12 max-w-3xl">
        {subtitle}
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
        {jurusan.map((j) => (
          <div class="bg-white rounded-2xl shadow hover:shadow-lg transition overflow-hidden">
            {j.gambar && (
              <img
                src={j.gambar}
                alt={`Jurusan ${j.nama}`}
                class="w-74 h-74 mx-auto mb-4 object-contain"
              />
            )}
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">{j.icon}</span>
                <h2 class="font-bold text-lg">{j.nama}</h2>
              </div>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">
                {j.deskripsi}
              </p>
              {j.kompetensi && j.kompetensi.length > 0 && (
                <ul class="text-sm text-gray-700 list-disc list-inside space-y-1">
                  {j.kompetensi.map((k) => (
                    <li>{k}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</MainLayout>
