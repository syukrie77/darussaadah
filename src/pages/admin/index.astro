---
import MainLayout from "../../layouts/MainLayout.astro";

const isDev = import.meta.env.DEV;
---

<MainLayout title="Admin CMS | SMK Bina Mandiri Kutabumi">
  <section class="min-h-[70vh] bg-slate-50 py-16">
    <div class="mx-auto max-w-3xl px-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">Admin Area</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-900">Akses Keystatic CMS</h1>
        <p class="mt-3 text-slate-600">
          Gunakan halaman ini untuk masuk ke panel admin dan mengelola konten website sekolah.
        </p>

        {isDev ? (
          <div class="mt-8 rounded-xl border border-emerald-200 bg-emerald-50 p-5">
            <p class="text-sm text-emerald-800">
              Mode development aktif. Klik tombol di bawah untuk membuka Keystatic CMS.
            </p>
            <a
              href="/keystatic"
              class="mt-4 inline-flex items-center rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
            >
              Masuk Keystatic CMS
            </a>
          </div>
        ) : (
          <div class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-5">
            <p class="text-sm text-amber-900">
              Panel Keystatic tidak aktif di mode production saat ini.
              Aktifkan integrasi `keystatic()` di `astro.config.mjs` jika ingin akses CMS di deployment.
            </p>
          </div>
        )}
      </div>
    </div>
  </section>
</MainLayout>
